{
  "name": "gestao-pdv-desktop",
  "version": "1.0.0",
  "description": "Enterprise Kiosk & Digital Signage PDV",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:linux": "electron-builder --linux deb"
  },
  "author": "GestãoPDV",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.gestaopdv.desktop",
    "productName": "GestãoPDV Desktop",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": ["deb"],
      "category": "Office"
    }
  }
}
