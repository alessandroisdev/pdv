{
  "name": "gestao-pdv-desktop",
  "version": "1.0.0",
  "description": "Frente de Caixa (PDV) - Enterprise Edition Desktop",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "author": "Alessandro JS Dev",
  "license": "MIT",
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.gestaopdv.desktop",
    "productName": "PDV Frente de Caixa",
    "win": {
      "target": ["nsis", "portable"],
      "icon": "icon.ico"
    },
    "linux": {
      "target": ["AppImage", "deb"]
    }
  }
}
