{
  "name": "debras-enterprise-pos",
  "version": "1.0.0",
  "description": "Frente de Caixa Nativa Offline-First",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "build:win": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable --x64",
    "build:linux": "electron-builder --linux deb",
    "build:all": "electron-builder --win nsis portable --linux deb"
  },
  "author": "Debras Engineering",
  "license": "ISC",
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.debras.pos",
    "productName": "Debras PDV",
    "win": {
      "target": ["portable", "nsis"]
    },
    "linux": {
      "target": ["AppImage"]
    }
  }
}
